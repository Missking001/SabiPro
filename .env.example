# =========================================================================
# SabiPro Environment Variables Template
# =========================================================================

# -------------------------------------------------------------------------
# Frontend (apps/web/.env.local)
# -------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                  # Generate a secure secret
NEXT_PUBLIC_API_URL=http://localhost:4000
JWT_SECRET=                       # Must match backend JWT_SECRET exactly

# -------------------------------------------------------------------------
# Backend (apps/api/.env)
# -------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sabipro?schema=public
JWT_SECRET=                       # Must match frontend JWT_SECRET exactly
SUPABASE_URL=                     # Supabase URL for file storage
SUPABASE_ANON_KEY=                # Supabase Anon/Public Key
SUPABASE_SERVICE_ROLE_KEY=        # Never expose to client!
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
FLW_PUBLIC_KEY=                   # Flutterwave Public Key (sandbox or live)
FLW_SECRET_KEY=                   # Flutterwave Secret Key (sandbox or live)
FLW_WEBHOOK_SECRET=               # Flutterwave Webhook Hash secret
ALLOWED_ORIGIN=http://localhost:3000
NODE_ENV=development
PLATFORM_FEE_PERCENT=10           # Percentage taken from transaction (integer, e.g. 10 for 10%)
ADMIN_SECRET_CODE=                # Single admin code for admin login (set this to your chosen code)
